{
  "enabledPlugins": {
    "github@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/prompt.py"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$NVIM\" ] && nvim --server \"$NVIM\" --remote-send '<cmd>checktime<cr>' || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:files.pythonhosted.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:objects.githubusercontent.com)",
      "WebFetch(domain:anthropic.com)",
      "WebFetch(domain:api.anthropic.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:static.crates.io)",
      "WebFetch(domain:docs.pola.rs)",
      "WebFetch(domain:pola.rs)"
    ]
  },
  "sandbox": {
    "enabled" : true,
    "filesystem": {
      "allowWrite": [
        "~/.cache/uv/"
      ]
    },
    "network": {
      "allowedDomains": [
        "pypi.org",
        "files.pythonhosted.org",
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "anthropic.com",
        "api.anthropic.com",
        "docs.anthropic.com",
        "crates.io",
        "static.crates.io",
        "docs.pola.rs",
        "pola.rs"
      ]
    }
  }
}

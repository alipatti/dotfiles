{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/prompt.py"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$NVIM\" ] && nvim --server \"$NVIM\" --remote-send '<cmd>checktime<cr>' || true"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled" : true,
    "filesystem": {
      "allowWrite": [
        "~/.cache/uv/"
      ]
    },
    "network": {
      "allowedDomains": [
        "pypi.org",
        "files.pythonhosted.org",
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "anthropic.com",
        "api.anthropic.com",
        "docs.anthropic.com",
        "crates.io",
        "static.crates.io",
        "docs.pola.rs"
      ]
    }
  }
}
